---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sampleIssues = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const valueProps = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    title: 'Evidence check',
    description: 'One popular health claim tested against the research. We tell you what holds up, what\u2019s overhyped, and what to actually do.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'One practical action',
    description: 'Every issue ends with a single, specific thing you can try this week. No 17-step protocols \u2014 one change that matters.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>`,
    title: 'No supplements, no sponsors',
    description: 'We don\u2019t sell products or run ads. Our only incentive is to be the most trustworthy health newsletter you read.',
  },
];

const readingPaths = [
  { label: 'Sleep fixes', href: '/start-here#sleep', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>' },
  { label: "Women\u2019s healthspan", href: '/start-here#women', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>' },
  { label: 'Everyday longevity', href: '/start-here#longevity', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>' },
  { label: 'Stress & nervous system', href: '/start-here#stress', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>' },
];

const faqs = [
  {
    q: 'How often do you send?',
    a: 'Once a week, on Sunday morning.',
  },
  {
    q: 'Is it really free?',
    a: 'Yes. No paywall, no upsells. We may add a premium tier later, but the weekly issue will always be free.',
  },
  {
    q: 'Who writes this?',
    a: 'Paresh Chauhan, founder of BestKarma. Every article goes through a structured editorial validation process with primary sources cited inline. We are actively building a medical advisory board \u2014 until then, we are transparent about our process and honest about the limits of what we know.',
  },
  {
    q: 'Can I unsubscribe?',
    a: 'One click, anytime. We\u2019d rather have 1,000 engaged readers than 10,000 who ignore us.',
  },
];
---

<BaseLayout
  title="Newsletter"
  description="BestKarma Weekly: one science-backed health and longevity insight every Sunday, with one thing you can act on that week."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-bark text-cream">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-20 right-0 h-80 w-80 rounded-full bg-sage/20 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-72 w-72 rounded-full bg-gold/20 blur-3xl"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-20">
      <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p class="text-sage-light text-sm font-semibold uppercase tracking-widest mb-4">BestKarma Weekly</p>
          <h1 class="font-heading text-4xl md:text-6xl font-semibold leading-tight">
            One insight. One action. Every Sunday.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-cream/75">
            BestKarma Weekly turns the best health and longevity research into something you can actually use — delivered free to your inbox.
          </p>
          <div class="mt-8 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-cream/15 bg-cream/5 p-4">
              <p class="text-sm font-semibold">5 minutes</p>
              <p class="mt-1 text-sm text-cream/65">Short enough to finish before breakfast.</p>
            </div>
            <div class="rounded-2xl border border-cream/15 bg-cream/5 p-4">
              <p class="text-sm font-semibold">Science-backed</p>
              <p class="mt-1 text-sm text-cream/65">Built from credible research and careful interpretation.</p>
            </div>
            <div class="rounded-2xl border border-cream/15 bg-cream/5 p-4">
              <p class="text-sm font-semibold">Action-first</p>
              <p class="mt-1 text-sm text-cream/65">Every issue ends with a practical next step.</p>
            </div>
          </div>
        </div>

        <div class="rounded-3xl border border-cream/10 bg-cream/10 p-8 backdrop-blur-sm">
          <p class="text-sm font-semibold uppercase tracking-widest text-sage-light">Join free</p>
          <h2 class="mt-3 font-heading text-3xl font-semibold">Subscribe now</h2>
          <ul class="mt-5 space-y-3 text-sm leading-relaxed text-cream/75">
            <li>One science-backed idea worth your attention this week.</li>
            <li>A short explanation of what the research actually supports.</li>
            <li>A realistic habit or experiment to try next.</li>
          </ul>
          <div class="mt-6">
            <NewsletterSignup variant="inline" source="newsletter-page-hero" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What you get -->
  <section class="px-6 py-16 bg-mist border-b border-sage-light/20">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10">
        <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-2">What you get</p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark">Every issue, every week.</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {valueProps.map((prop) => (
          <div class="rounded-2xl border border-border bg-white p-6 shadow-sm">
            <div class="w-10 h-10 rounded-xl bg-sage-light/30 flex items-center justify-center text-sage-dark mb-4" set:html={prop.icon} />
            <h3 class="font-heading text-xl font-semibold text-bark mb-2">{prop.title}</h3>
            <p class="text-sm leading-relaxed text-stone">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sample issues -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-2">Sample issues</p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark">Recent topics from the archive</h2>
      </div>
      <p class="max-w-xl text-stone">
        These articles show the kind of practical, science-backed guidance subscribers can expect.
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sampleIssues.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id.replace(/\.mdx?$/, '')}
          category={post.data.category}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          readTime={post.data.readTime}
        />
      ))}
    </div>
  </section>

  <!-- What readers say -->
  <section class="border-y border-border bg-cream-dark/50">
    <div class="max-w-4xl mx-auto px-6 py-16 text-center">
      <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-6">What readers say</p>
      <blockquote class="rounded-2xl border border-border bg-white p-8 shadow-sm max-w-2xl mx-auto">
        <p class="font-heading text-xl md:text-2xl font-semibold text-bark leading-snug italic">
          "The only health newsletter I actually read every week."
        </p>
        <p class="mt-4 text-stone-light text-sm">— Placeholder for future testimonial</p>
      </blockquote>
    </div>
  </section>

  <!-- What we cover -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="mb-8">
      <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-2">What we cover</p>
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark">Four reading paths to explore</h2>
      <p class="mt-3 text-stone text-lg max-w-2xl">
        Every issue draws from one of these core topics. Pick the path that matters to you, or follow along each week.
      </p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {readingPaths.map((rp) => (
        <a
          href={rp.href}
          class="group rounded-2xl border border-border bg-white p-6 hover:border-sage-light hover:shadow-sm transition-all"
        >
          <div class="text-sage-dark mb-3" set:html={rp.icon} />
          <h3 class="font-heading text-lg font-semibold text-bark group-hover:text-sage-dark transition-colors">{rp.label}</h3>
          <p class="mt-2 text-sage-dark text-sm font-medium">Explore path &rarr;</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="border-t border-border bg-cream-dark/40">
    <div class="max-w-2xl mx-auto px-6 py-16 text-center">
      <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-3">Ready?</p>
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark">
        Join BestKarma Weekly
      </h2>
      <p class="mt-4 text-stone text-lg leading-relaxed mb-8">
        One idea, one action, every Sunday. Free forever.
      </p>
      <div class="max-w-md mx-auto">
        <NewsletterSignup variant="inline" source="newsletter-page-bottom" />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-border">
    <div class="max-w-3xl mx-auto px-6 py-16">
      <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-2">FAQ</p>
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark mb-10">Common questions</h2>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="rounded-2xl border border-border bg-white p-6">
            <h3 class="font-heading text-lg font-semibold text-bark">{faq.q}</h3>
            <p class="mt-2 text-stone text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
