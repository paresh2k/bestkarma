---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sampleIssues = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Newsletter"
  description="Subscribe for one practical, science-backed health and longevity insight every Sunday."
>
  <section class="relative overflow-hidden bg-bark text-cream">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-20 right-0 h-80 w-80 rounded-full bg-sage/20 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-72 w-72 rounded-full bg-gold/20 blur-3xl"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-20">
      <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p class="text-sage-light text-sm font-semibold uppercase tracking-widest mb-4">BestKarma Weekly</p>
          <h1 class="font-heading text-4xl md:text-6xl font-semibold leading-tight">
            Live well. Age wisely.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-cream/75">
            BestKarma Weekly turns credible health and longevity research into clear, practical guidance you can use: one idea, one takeaway, and enough context to understand why it matters.
          </p>
          <div class="mt-8 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-cream/15 bg-cream/5 p-4">
              <p class="text-sm font-semibold">5 minutes</p>
              <p class="mt-1 text-sm text-cream/65">Short enough to finish before breakfast.</p>
            </div>
            <div class="rounded-2xl border border-cream/15 bg-cream/5 p-4">
              <p class="text-sm font-semibold">Science-backed</p>
              <p class="mt-1 text-sm text-cream/65">Built from credible research and careful interpretation.</p>
            </div>
            <div class="rounded-2xl border border-cream/15 bg-cream/5 p-4">
              <p class="text-sm font-semibold">Action-first</p>
              <p class="mt-1 text-sm text-cream/65">Every issue ends with a practical next step.</p>
            </div>
          </div>
        </div>

        <div class="rounded-3xl border border-cream/10 bg-cream/10 p-8 backdrop-blur-sm">
          <p class="text-sm font-semibold uppercase tracking-widest text-sage-light">Join free</p>
          <h2 class="mt-3 font-heading text-3xl font-semibold">What you get</h2>
          <ul class="mt-5 space-y-3 text-sm leading-relaxed text-cream/75">
            <li>One science-backed idea worth your attention this week.</li>
            <li>A short explanation of what the research actually supports.</li>
            <li>A realistic habit or experiment to try next.</li>
          </ul>
          <div class="mt-6">
            <NewsletterSignup variant="inline" source="newsletter-page" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-2">Sample issues</p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark">Recent topics from the archive</h2>
      </div>
      <p class="max-w-xl text-stone">
        These articles show the kind of practical, science-backed guidance subscribers can expect.
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sampleIssues.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id.replace(/\.mdx?$/, '')}
          category={post.data.category}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          readTime={post.data.readTime}
        />
      ))}
    </div>
  </section>

  <section class="border-t border-border bg-cream-dark/50">
    <div class="max-w-4xl mx-auto px-6 py-16 text-center">
      <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-3">Why this exists</p>
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark">A calmer alternative to health overload</h2>
      <p class="mt-4 text-lg leading-relaxed text-stone">
        BestKarma Weekly is for readers who want useful guidance without chasing every trend. We focus on ideas that are practical, science-backed, and worth your time.
      </p>
    </div>
  </section>
</BaseLayout>
