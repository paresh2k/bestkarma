---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../lib/categories';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Articles — BestKarma"
  description="Browse all wellness and longevity articles from BestKarma. Science-backed insights on nutrition, sleep, mind-body health, and living longer."
>
  <!-- Header -->
  <div class="bg-cream-dark border-b border-border">
    <div class="max-w-6xl mx-auto px-6 py-14">
      <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-3">Knowledge base</p>
      <h1 class="font-heading text-4xl md:text-5xl font-semibold text-bark mb-4">
        All Articles
      </h1>
      <p class="text-stone text-lg max-w-xl">
        {sortedPosts.length} evidence-based articles on living well.
      </p>

      <!-- Category filter -->
      <div class="flex flex-wrap gap-2 mt-8" id="category-filters">
        {[{ label: 'All', slug: 'all' }, ...categories].map(cat => (
          <button
            data-filter={cat.slug}
            class={`px-4 py-2 rounded-full text-sm font-medium transition-colors cursor-pointer filter-btn ${
              cat.slug === 'all'
                ? 'bg-sage text-cream'
                : 'bg-cream border border-border text-stone hover:border-sage-light hover:text-sage-dark'
            }`}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Articles grid -->
  <div class="max-w-6xl mx-auto px-6 py-14">
    <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedPosts.map(post => (
        <div data-category={post.data.category}>
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id.replace(/\.mdx?$/, '')}
            category={post.data.category}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            readTime={post.data.readTime}
          />
        </div>
      ))}
    </div>
    <p id="no-results" class="hidden text-center py-20 font-heading text-2xl text-stone">
      No articles yet in this category.
    </p>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('#articles-grid [data-category]');
  const noResults = document.getElementById('no-results');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      // Update active button styles
      buttons.forEach(b => {
        b.classList.remove('bg-sage', 'text-cream');
        b.classList.add('bg-cream', 'border', 'border-border', 'text-stone');
      });
      btn.classList.add('bg-sage', 'text-cream');
      btn.classList.remove('bg-cream', 'border', 'border-border', 'text-stone');

      // Show/hide cards
      let visible = 0;
      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      noResults?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
