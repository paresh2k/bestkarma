---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';
import { categories } from '../lib/categories';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = sortedPosts.slice(0, 3);
const articleCount = sortedPosts.length;
const latestReviewDate = sortedPosts[0]?.data.reviewedDate ?? new Date();

const proofPoints = [
  { label: 'Published articles', value: String(articleCount).padStart(2, '0') },
  { label: 'Editorial pillars', value: String(categories.length).padStart(2, '0') },
  {
    label: 'Latest review pass',
    value: latestReviewDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
  },
];

const franchises = [
  {
    title: 'Weekly Evidence Check',
    description: 'A recurring format that tests one popular health claim against the actual quality of the evidence.',
  },
  {
    title: 'Sunday Reset',
    description: 'A short routine and planning brief that turns research into one realistic action for the week ahead.',
  },
  {
    title: 'Longevity Notes',
    description: 'A tighter editorial stream for adults who care about healthy aging without adopting a full-time optimization hobby.',
  },
];
---

<BaseLayout title="BestKarma — Live Well, Age Wisely, Thrive Daily">

  <section class="relative overflow-hidden bg-cream pt-10 pb-14 md:pt-14 md:pb-18">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-32 right-8 h-96 w-96 rounded-full bg-sage-light/15 blur-2xl"></div>
      <div class="absolute bottom-0 left-0 h-80 w-80 rounded-full bg-gold-light/25 blur-2xl"></div>
      <div class="absolute inset-x-0 top-40 h-px bg-gradient-to-r from-transparent via-sage-light/40 to-transparent"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6">
      <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 rounded-full bg-sage-light/30 px-4 py-2 text-xs font-semibold tracking-wide text-sage-dark mb-6">
            <span class="h-1.5 w-1.5 rounded-full bg-sage-dark"></span>
            Calm, science-backed wellness
          </div>

          <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-semibold text-bark leading-tight mb-5">
            Wellness guidance for people who want evidence,
            <span class="text-sage"> not chaos.</span>
          </h1>

          <p class="text-stone text-lg md:text-xl leading-relaxed mb-8 max-w-2xl">
            BestKarma turns longevity and health research into useful routines for real life. Less hype, more clarity, and a steadier way to think about the long game.
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href="/blog"
              class="inline-flex items-center gap-2 bg-bark text-cream font-semibold px-7 py-3.5 rounded-full hover:bg-stone transition-colors text-base"
            >
              Explore Articles
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
            <a
              href="/newsletter"
              class="inline-flex items-center gap-2 rounded-full border border-bark/10 bg-white/70 px-7 py-3.5 text-base font-semibold text-bark hover:border-sage-light hover:text-sage-dark transition-colors"
            >
              See the newsletter
            </a>
          </div>
        </div>

        <div class="rounded-[2rem] border border-bark/8 bg-white/65 p-6 shadow-sm backdrop-blur-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sage-dark">Editorial proof</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
            {proofPoints.map((item) => (
              <div class="rounded-2xl border border-border bg-cream-dark/50 px-4 py-5">
                <p class="font-heading text-3xl font-semibold text-bark">{item.value}</p>
                <p class="mt-1 text-sm leading-relaxed text-stone">{item.label}</p>
              </div>
            ))}
          </div>
          <div class="mt-5 rounded-2xl bg-bark px-5 py-5 text-cream">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sage-light">House view</p>
            <p class="mt-3 text-sm leading-relaxed text-cream/75">
              If a claim is thin, overhyped, or impractical, it should not survive the editorial process.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter — dedicated block with clear value props -->
  <section class="bg-mist border-y border-sage-light/30 py-10 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-16">

        <!-- Left: what you get -->
        <div class="flex-1 min-w-0">
          <p class="text-sage-dark text-xs font-semibold uppercase tracking-widest mb-2">Free Weekly Newsletter</p>
          <h2 class="font-heading text-2xl md:text-3xl font-semibold text-bark mb-4">
            One insight. Every Sunday.<br class="hidden md:block" /> Backed by science.
          </h2>
          <ul class="space-y-2.5">
            <li class="flex items-start gap-2.5 text-stone text-sm">
              <svg class="w-4 h-4 mt-0.5 text-sage shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span><strong class="text-bark font-medium">Evidence-based only</strong> — every claim cites peer-reviewed research, no fads or supplement hype</span>
            </li>
            <li class="flex items-start gap-2.5 text-stone text-sm">
              <svg class="w-4 h-4 mt-0.5 text-sage shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span><strong class="text-bark font-medium">Practical takeaways</strong> — science distilled into one thing you can act on this week</span>
            </li>
            <li class="flex items-start gap-2.5 text-stone text-sm">
              <svg class="w-4 h-4 mt-0.5 text-sage shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span><strong class="text-bark font-medium">Covers 5 core pillars</strong> — longevity, wellness, sleep, nutrition, and mind-body health</span>
            </li>
          </ul>
        </div>

        <!-- Right: signup form -->
        <div class="md:w-80 lg:w-96 shrink-0">
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-border">
            <p class="text-bark font-semibold text-base mb-1">Join free — no spam, ever.</p>
            <p class="text-stone-light text-sm mb-4">Unsubscribe with one click, anytime.</p>
            <NewsletterSignup variant="hero" source="homepage-hero" />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  {featuredPosts.length > 0 && (
    <section class="py-16 px-6 bg-cream-dark/50">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-2">Latest</p>
            <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark">From the archive</h2>
          </div>
          <a href="/blog" class="hidden md:inline-flex items-center gap-1 text-sage-dark hover:text-sage font-medium text-sm transition-colors">
            All articles
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredPosts.map((post, i) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id.replace(/\.mdx?$/, '')}
              category={post.data.category}
              pubDate={post.data.pubDate}
              heroImage={post.data.heroImage}
              readTime={post.data.readTime}
              featured={i === 0}
            />
          ))}
        </div>

        <div class="mt-8 md:hidden">
          <a href="/blog" class="inline-flex items-center gap-1 text-sage-dark font-medium text-sm">
            View all articles →
          </a>
        </div>
      </div>
    </section>
  )}

  <section class="px-6 py-18">
    <div class="max-w-6xl mx-auto rounded-[2rem] border border-border bg-bark px-8 py-10 text-cream md:px-10">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-sage-light text-sm font-semibold uppercase tracking-widest mb-3">Editorial Franchises</p>
          <h2 class="font-heading text-3xl md:text-4xl font-semibold">Formats that can become habits, not just posts.</h2>
          <p class="mt-4 text-cream/70 text-lg leading-relaxed">
            The next step for BestKarma is repeatable editorial products that help readers know what to expect and why to return.
          </p>
        </div>
        <a href="/newsletter" class="inline-flex items-center gap-2 text-sm font-medium text-sage-light hover:text-cream transition-colors">
          Preview the newsletter
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {franchises.map((franchise) => (
          <div class="rounded-2xl border border-cream/10 bg-cream/5 p-6">
            <h3 class="font-heading text-2xl font-semibold text-cream">{franchise.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-cream/70">{franchise.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Topics Grid -->
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-3">Topics</p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark">What we cover</h2>
        <p class="text-stone mt-3 text-lg max-w-xl mx-auto">
          Five editorial pillars, each with a clearer hub for readers who want to go deeper.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
        {categories.map(topic => (
          <a
            href={topic.href}
            class="group flex flex-col p-6 rounded-2xl bg-cream-dark border border-border hover:border-sage-light hover:shadow-md transition-all duration-300"
          >
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 ${topic.colorClass}`} set:html={topic.icon} />
            <h3 class="font-heading font-semibold text-bark text-lg mb-2 group-hover:text-sage-dark transition-colors">
              {topic.label}
            </h3>
            <p class="text-stone text-sm leading-relaxed flex-1">
              {topic.description}
            </p>
            <span class="mt-4 text-sage-dark text-sm font-medium group-hover:gap-2 flex items-center gap-1 transition-all">
              Explore
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter banner (bottom of page) -->
  <NewsletterSignup variant="banner" source="homepage-banner" />

  <!-- About teaser -->
  <section class="py-20 px-6 bg-cream-dark/40">
    <div class="max-w-4xl mx-auto text-center">
      <div class="w-16 h-0.5 bg-sage mx-auto mb-8"></div>
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-bark mb-5">
        Science-backed. Human-curated.
      </h2>
      <p class="text-stone text-lg leading-relaxed max-w-2xl mx-auto">
        BestKarma exists at the intersection of cutting-edge longevity research and practical, everyday wellness. We cut through the noise so you don't have to.
      </p>
      <a href="/about" class="inline-flex items-center gap-2 mt-8 text-sage-dark font-medium hover:text-sage transition-colors">
        Our story →
      </a>
    </div>
  </section>

</BaseLayout>
