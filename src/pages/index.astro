// To restore the full landing page: delete this file and rename index.astro.bak → index.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BestKarma</title>
  <meta name="description" content="Live Well. Age Wisely." />
  <meta property="og:title" content="BestKarma" />
  <meta property="og:description" content="Live Well. Age Wisely." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #FAF7F0;
    }

    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100dvh;
      font-family: 'Jost', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .lockup {
      display: flex;
      flex-direction: column;
      align-items: center;
      animation: rise 1.4s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes rise {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .mark {
      width: 44px;
      height: 44px;
      margin-bottom: 14px;
      opacity: 0.9;
    }

    .wordmark {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 13px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: #1D9E75;
      margin-bottom: 48px;
    }

    .tagline {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(2rem, 5vw, 3rem);
      color: #2C2417;
      letter-spacing: 0.01em;
      text-align: center;
      line-height: 1.25;
    }

    .tagline em {
      font-style: italic;
      color: #1D9E75;
    }

    .divider {
      width: 32px;
      height: 1px;
      background: #C9BFB0;
      margin: 36px auto 0;
    }
  </style>
</head>
<body>
  <div class="lockup">

    <svg class="mark" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M22 6C22 6 10 14 10 24C10 30.627 15.373 36 22 36C28.627 36 34 30.627 34 24C34 14 22 6 22 6Z" fill="#1D9E75" fill-opacity="0.15"/>
      <path d="M22 6C22 6 10 14 10 24C10 30.627 15.373 36 22 36C28.627 36 34 30.627 34 24C34 14 22 6 22 6Z" stroke="#1D9E75" stroke-width="1.25" stroke-linejoin="round"/>
      <path d="M22 36L22 18" stroke="#1D9E75" stroke-width="1.25" stroke-linecap="round"/>
      <path d="M22 26C22 26 17 22 14 18" stroke="#1D9E75" stroke-width="1.25" stroke-linecap="round"/>
      <path d="M22 22C22 22 27 19 30 16" stroke="#1D9E75" stroke-width="1.25" stroke-linecap="round"/>
    </svg>

    <p class="wordmark">BestKarma</p>
    <h1 class="tagline">Live Well. <em>Age Wisely.</em></h1>
    <div class="divider"></div>

  </div>
</body>
</html>
