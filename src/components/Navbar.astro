---
import { categories } from '../lib/categories';

const navLinks = categories.map(({ label, href }) => ({ label, href }));
---

<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-border">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <img src="/logo.svg" alt="" width="36" height="36" class="flex-shrink-0 transition-transform group-hover:scale-105 duration-200" />
      <span class="text-xl font-heading font-semibold text-bark group-hover:text-sage-dark transition-colors">
        Best<span class="text-sage">Karma</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-5">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="whitespace-nowrap text-stone hover:text-sage-dark font-medium text-sm transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="flex items-center gap-4">
      <a
        href="/blog"
        class="hidden lg:inline-block text-sm font-medium text-stone hover:text-bark transition-colors"
      >
        Articles
      </a>
      <a
        href="/newsletter"
        class="inline-flex items-center gap-2 bg-sage text-cream text-sm font-medium px-5 py-2.5 rounded-full hover:bg-sage-dark transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <span class="hidden sm:inline">Newsletter</span>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg hover:bg-cream-dark transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"/>
          <line x1="4" x2="20" y1="6" y2="6"/>
          <line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <path d="M18 6 6 18"/>
          <path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-cream">
    <ul class="max-w-6xl mx-auto px-8 py-5 flex flex-col gap-5">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="block text-stone hover:text-sage-dark font-medium py-2 text-lg transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-3 border-t border-border">
        <a href="/newsletter" class="block text-stone hover:text-bark font-medium py-2 text-lg transition-colors">
          Newsletter
        </a>
      </li>
      <li>
        <a href="/blog" class="block text-stone hover:text-bark font-medium py-2 text-lg transition-colors">
          All Articles
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', !isOpen);
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
