---
import { categories } from '../lib/categories';

const year = new Date().getFullYear();
---

<footer class="bg-bark text-cream/80 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="text-2xl font-heading font-semibold text-cream">
          Best<span class="text-sage-light">Karma</span>
        </a>
        <p class="mt-4 text-cream/60 text-sm leading-relaxed max-w-xs">
          Science-backed wellness for the long game. Live well, age wisely, thrive daily.
        </p>
        <p class="mt-6 text-xs leading-relaxed text-cream/40 max-w-sm">
          BestKarma publishes educational wellness content. It is not medical advice and should not replace care from a licensed clinician.
        </p>
      </div>

      <!-- Topics -->
      <div>
        <h3 class="text-cream font-semibold text-sm uppercase tracking-wider mb-5">Explore</h3>
        <ul class="space-y-3">
          {categories.map(cat => (
            <li>
              <a href={cat.href} class="text-cream/60 hover:text-cream text-sm transition-colors">
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter mini -->
      <div>
        <h3 class="text-cream font-semibold text-sm uppercase tracking-wider mb-5">Weekly Wellness</h3>
        <p class="text-cream/60 text-sm mb-4 leading-relaxed">
          One evidence-based insight, every week. No fluff.
        </p>
        <a
          href="/newsletter"
          class="inline-block bg-sage text-cream text-sm font-medium px-5 py-2.5 rounded-full hover:bg-sage-dark transition-colors"
        >
          Join the newsletter →
        </a>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-cream/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-cream/40">
      <p>&copy; {year} BestKarma. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/editorial-standards" class="hover:text-cream/60 transition-colors">Editorial Standards</a>
        <a href="/privacy" class="hover:text-cream/60 transition-colors">Privacy</a>
        <a href="/about" class="hover:text-cream/60 transition-colors">About</a>
      </div>
    </div>
  </div>
</footer>
