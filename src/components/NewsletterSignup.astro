---
interface Props {
  variant?: 'hero' | 'inline' | 'banner';
  source?: string;
}

const { variant = 'inline', source = 'website' } = Astro.props;

const formId = `newsletter-${variant}-${Math.random().toString(36).slice(2, 7)}`;
---

{variant === 'banner' ? (
  <section id="newsletter" class="bg-sage py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sage-light text-sm font-semibold uppercase tracking-widest mb-4">Weekly Wellness</p>
      <h2 class="font-heading text-4xl md:text-5xl font-semibold text-cream mb-4">
        Wisdom for the long game
      </h2>
      <p class="text-cream/75 text-lg mb-10 leading-relaxed">
        One evidence-based insight every week. No fluff, no fads — just the science of living well, delivered to your inbox.
      </p>

      <form
        id={formId}
        class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
        novalidate
      >
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 px-5 py-3.5 rounded-full bg-cream/10 border border-cream/20 text-cream placeholder-cream/50 focus:outline-none focus:ring-2 focus:ring-cream/40 text-sm"
        />
        <button
          type="submit"
          class="submit-btn px-6 py-3.5 bg-cream text-sage-dark font-semibold rounded-full hover:bg-gold-light transition-colors text-sm whitespace-nowrap disabled:opacity-60"
        >
          Join Free →
        </button>
      </form>

      <p class="success-msg hidden text-cream font-medium mt-4">🎉 You're in! Check your inbox to confirm.</p>
      <p class="error-msg hidden text-red-200 text-sm mt-4"></p>
      <p class="text-cream/40 text-xs mt-4 no-msg">No spam, ever. Unsubscribe anytime.</p>
    </div>
  </section>
) : variant === 'hero' ? (
  <form
    id={formId}
    class="flex flex-col sm:flex-row gap-3 max-w-sm"
    novalidate
  >
    <input
      type="email"
      name="email"
      required
      placeholder="your@email.com"
      class="flex-1 px-5 py-3 rounded-full bg-white/80 border border-border text-bark placeholder-stone-light focus:outline-none focus:ring-2 focus:ring-sage-light text-sm"
    />
    <button
      type="submit"
      class="submit-btn px-6 py-3 bg-terracotta text-cream font-semibold rounded-full hover:bg-terracotta/90 transition-colors text-sm whitespace-nowrap disabled:opacity-60"
    >
      Join Free
    </button>
    <p class="success-msg hidden w-full text-sage-dark text-sm font-medium mt-1">🎉 Check your inbox to confirm!</p>
    <p class="error-msg hidden w-full text-red-600 text-xs mt-1"></p>
  </form>
) : (
  <div class="bg-mist border border-sage-light/30 rounded-2xl p-8">
    <h3 class="font-heading text-2xl font-semibold text-bark mb-2">Stay in the loop</h3>
    <p class="text-stone text-sm mb-5">Weekly wellness insights, science-backed and human-curated.</p>
    <form
      id={formId}
      class="flex flex-col sm:flex-row gap-3"
      novalidate
    >
      <input
        type="email"
        name="email"
        required
        placeholder="your@email.com"
        class="flex-1 px-4 py-3 rounded-full bg-cream border border-border text-bark placeholder-stone-light focus:outline-none focus:ring-2 focus:ring-sage-light text-sm"
      />
      <button
        type="submit"
        class="submit-btn px-6 py-3 bg-sage text-cream font-medium rounded-full hover:bg-sage-dark transition-colors text-sm disabled:opacity-60"
      >
        Subscribe
      </button>
    </form>
    <p class="success-msg hidden text-sage-dark text-sm font-medium mt-3">🎉 You're in! Check your inbox to confirm.</p>
    <p class="error-msg hidden text-red-600 text-xs mt-2"></p>
    <p class="text-stone-light text-xs mt-3 no-msg">Free, weekly, unsubscribe anytime.</p>
  </div>
)}

<script define:vars={{ formId, source }}>
  const form = document.getElementById(formId);
  if (!form) return;

  const btn = form.querySelector('.submit-btn');
  const successMsg = form.parentElement?.querySelector('.success-msg') ?? form.querySelector('.success-msg');
  const errorMsg = form.parentElement?.querySelector('.error-msg') ?? form.querySelector('.error-msg');
  const noMsg = form.parentElement?.querySelector('.no-msg');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = form.querySelector('input[type="email"]').value.trim();

    btn.disabled = true;
    btn.textContent = 'Subscribing…';
    if (errorMsg) { errorMsg.classList.add('hidden'); errorMsg.textContent = ''; }

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source }),
      });

      const data = await res.json();

      if (res.ok && data.success) {
        if (successMsg) {
          // Hide every sibling of successMsg (works for all variants)
          const container = successMsg.parentElement;
          if (container) {
            Array.from(container.children).forEach(el => {
              if (el !== successMsg) el.classList.add('hidden');
            });
          }
          successMsg.classList.remove('hidden');
        }
      } else {
        throw new Error(data.error || 'Something went wrong. Please try again.');
      }
    } catch (err) {
      btn.disabled = false;
      btn.textContent = btn.dataset.label ?? 'Subscribe';
      if (errorMsg) {
        errorMsg.textContent = err.message;
        errorMsg.classList.remove('hidden');
      }
    }
  });

  // Store original label
  if (btn) btn.dataset.label = btn.textContent.trim();
</script>
