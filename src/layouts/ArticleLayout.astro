---
import BaseLayout from './BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getCategory } from '../lib/categories';
import { getEditorialProfile } from '../lib/editorial';
import fs from 'node:fs/promises';
import path from 'node:path';
import ArticleCard from '../components/ArticleCard.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  author: string;
  reviewer: string;
  pubDate: Date;
  reviewedDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category: string;
  tags?: string[];
  readTime?: number;
  relatedPosts?: Array<{
    title: string;
    description: string;
    slug: string;
    category: string;
    pubDate: Date;
    heroImage?: string;
    readTime?: number;
  }>;
}

const {
  slug,
  title,
  description,
  author,
  reviewer,
  pubDate,
  reviewedDate,
  updatedDate,
  heroImage,
  category,
  tags = [],
  readTime = 5,
  relatedPosts = [],
} = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedReviewedDate = reviewedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const categoryMeta = getCategory(category);
const authorProfile = getEditorialProfile(author);
const reviewerProfile = getEditorialProfile(reviewer);
const bundleDir = path.join(process.cwd(), 'content-system', 'published', `${slug}.bundle`);

let sourceSummary: { sourceCount?: number; note?: string } | null = null;
try {
  const sourcesFile = await fs.readFile(path.join(bundleDir, 'sources.json'), 'utf8');
  sourceSummary = JSON.parse(sourcesFile);
} catch {}

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? reviewedDate).toISOString(),
  author: authorProfile
    ? {
        '@type': 'Person',
        name: authorProfile.name,
        description: authorProfile.credentials,
      }
    : undefined,
  publisher: {
    '@type': 'Organization',
    name: 'BestKarma',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/logo-wordmark.svg', Astro.site ?? Astro.url).toString(),
    },
  },
  image: heroImage ? new URL(heroImage, Astro.url).toString() : new URL('/og-default.svg', Astro.url).toString(),
  articleSection: categoryMeta?.label ?? category,
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: new URL('/', Astro.site ?? Astro.url).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Articles',
      item: new URL('/blog', Astro.site ?? Astro.url).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: categoryMeta?.label ?? category,
      item: new URL(categoryMeta?.href ?? `/blog?category=${category}`, Astro.site ?? Astro.url).toString(),
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: title,
      item: new URL(`/blog/${slug}`, Astro.site ?? Astro.url).toString(),
    },
  ],
};
---

<BaseLayout title={title} description={description} image={heroImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>
  <article>
    <!-- Hero -->
    <div class="bg-cream-dark border-b border-border">
      <div class="max-w-3xl mx-auto px-6 pt-12 pb-10">
        <!-- Category breadcrumb -->
        <div class="flex items-center gap-2 mb-6 text-sm">
          <a href="/blog" class="text-stone hover:text-sage-dark transition-colors">Articles</a>
          <span class="text-stone-light">/</span>
          <a href={categoryMeta?.href ?? `/blog?category=${category.toLowerCase()}`} class="text-sage-dark hover:text-sage font-medium transition-colors">
            {categoryMeta?.label ?? category}
          </a>
        </div>

        <!-- Title -->
        <h1 class="font-heading text-4xl md:text-5xl font-semibold text-bark leading-tight mb-5">
          {title}
        </h1>

        <!-- Description -->
        <p class="text-stone text-xl leading-relaxed mb-8">
          {description}
        </p>

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-6 text-sm text-stone-light pb-8 border-b border-border">
          <time datetime={pubDate.toISOString()}>
            Published {formattedPubDate}
          </time>
          <time datetime={reviewedDate.toISOString()}>
            Reviewed {formattedReviewedDate}
          </time>
          {updatedDate && (
            <time datetime={updatedDate.toISOString()}>
              Updated {formattedUpdatedDate}
            </time>
          )}
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            {readTime} min read
          </span>
        </div>
      </div>
    </div>

    <!-- Hero image -->
    {heroImage && (
      <div class="max-w-5xl mx-auto px-6 -mt-1">
        <img
          src={heroImage}
          alt={title}
          class="w-full h-72 md:h-[480px] object-cover rounded-2xl shadow-lg"
          loading="eager"
        />
      </div>
    )}

    <!-- Article body -->
    <div class="max-w-3xl mx-auto px-6 py-12">
      <div class="prose prose-lg prose-bestkarma max-w-none">
        <slot />
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-2">
        {authorProfile && (
          <div class="rounded-2xl border border-border bg-white/70 p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sage-dark">Written By</p>
            <h3 class="mt-2 font-heading text-2xl font-semibold text-bark">{authorProfile.name}</h3>
            <p class="mt-1 text-sm font-medium text-stone">{authorProfile.role} · {authorProfile.credentials}</p>
            <p class="mt-3 text-sm leading-relaxed text-stone">{authorProfile.bio}</p>
          </div>
        )}
        {reviewerProfile && (
          <div class="rounded-2xl border border-border bg-white/70 p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sage-dark">Reviewed By</p>
            <h3 class="mt-2 font-heading text-2xl font-semibold text-bark">{reviewerProfile.name}</h3>
            <p class="mt-1 text-sm font-medium text-stone">{reviewerProfile.role} · {reviewerProfile.credentials}</p>
            <p class="mt-3 text-sm leading-relaxed text-stone">{reviewerProfile.bio}</p>
          </div>
        )}
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mt-12 pt-8 border-t border-border">
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <a href={`/tags/${tag}`} class="text-xs font-medium px-3 py-1.5 bg-mist text-stone rounded-full capitalize hover:bg-sage-light/40 hover:text-sage-dark transition-colors">
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mt-10 rounded-2xl border border-border bg-cream-dark/50 px-6 py-5">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sage-dark">References and Review</p>
        <p class="mt-2 text-sm leading-relaxed text-stone">
          {sourceSummary?.sourceCount
            ? `This article includes ${sourceSummary.sourceCount} inline reference${sourceSummary.sourceCount === 1 ? '' : 's'} in the body.`
            : 'This article cites references inline in the body.'}
          {' '}
          {sourceSummary?.note ?? 'We review articles before publication and update them when needed.'}
        </p>
      </div>

      <div class="mt-10 rounded-2xl border border-sage-light/40 bg-mist px-6 py-5">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sage-dark">Health Content Notice</p>
        <p class="mt-2 text-sm leading-relaxed text-stone">
          BestKarma content is for education only. It should not be used to diagnose, treat, cure, or prevent any condition, and it is not a substitute for care from a qualified medical professional.
        </p>
      </div>

      <!-- Newsletter inline -->
      <div class="mt-12">
        <div class="mb-4">
          <p class="font-heading text-xl font-semibold text-bark">Enjoyed this?</p>
          <p class="text-stone text-sm mt-1">
            BestKarma Weekly sends one science-backed insight like this every Sunday — with one thing you can act on that week. No hype, no spam.
          </p>
        </div>
        <NewsletterSignup variant="inline" source={`article-${slug}`} />
      </div>

      <!-- Back links -->
      <div class="mt-10 flex items-center justify-between">
        <a href="/blog" class="inline-flex items-center gap-2 text-sage-dark hover:text-sage font-medium text-sm transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
          </svg>
          All articles
        </a>
        <a href="/start-here" class="inline-flex items-center gap-2 text-sage-dark hover:text-sage font-medium text-sm transition-colors">
          Start Here
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    {relatedPosts.length > 0 && (
      <section class="border-t border-border bg-cream-dark/35">
        <div class="max-w-6xl mx-auto px-6 py-14">
          <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-sage-dark text-sm font-semibold uppercase tracking-widest mb-2">Next Best Reads</p>
              <h2 class="font-heading text-3xl font-semibold text-bark">Keep the thread going</h2>
            </div>
            <p class="max-w-xl text-stone">
              More reading from the same topic cluster, chosen to extend the idea rather than restart it.
            </p>
          </div>

          <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {relatedPosts.map((post) => (
              <ArticleCard
                title={post.title}
                description={post.description}
                slug={post.slug}
                category={post.category}
                pubDate={post.pubDate}
                heroImage={post.heroImage}
                readTime={post.readTime}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>
